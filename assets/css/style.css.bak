*{box-sizing:border-box;margin:0;padding:0}
.hd{background:#FFFDF7;color:#2E2E2E;font-size:13px;line-height:1.5;font-family:inherit}
.topbar{background:#ffffff;border-bottom:2px solid #F0E6D6;padding:12px 24px;display:flex;align-items:center;justify-content:space-between;gap:16px;position:sticky;top:0;z-index:1000;box-shadow:0 2px 16px rgba(0,0,0,.10)}
.logo{display:flex;align-items:center}
.topbar-logo{height:80px;width:auto;display:block;object-fit:contain}
.topbar-title{flex:1;text-align:center;font-size:22px;font-weight:700;white-space:nowrap;color:#2E2E2E;letter-spacing:0.01em}
.panel{display:block;padding:24px 28px;border-top:2px solid #F0E6D6}
.panel:first-of-type{border-top:none}

/* ── Section header ── */
.sec-hdr{display:flex;align-items:flex-end;justify-content:space-between;gap:16px;margin-bottom:20px;padding-bottom:14px;border-bottom:1.5px solid #F0E6D6;flex-wrap:wrap}
.sec-hdr-left{display:flex;flex-direction:column;gap:3px}
.sec-label{display:inline-flex;align-items:center;gap:6px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.12em;color:#A8A8A8}
.sec-label::before{content:'';display:inline-block;width:8px;height:8px;border-radius:50%;background:var(--sl,#F2A900);flex-shrink:0}
.sec-title{font-size:20px;font-weight:700;color:#1E1E1E;line-height:1.2}
.sec-sub{font-size:12px;color:#8A8A8A;margin-top:2px}

/* legacy */
.sh{font-size:11px;text-transform:uppercase;letter-spacing:.1em;color:#A8A8A8;font-weight:500;margin-bottom:3px}
.st{font-size:18px;font-weight:600;margin-bottom:16px}

.kpi-g{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:12px;margin-bottom:20px}
.kc{background:#fff;border-radius:14px;padding:16px 14px;box-shadow:0 3px 12px rgba(0,0,0,.06);position:relative;overflow:hidden;transition:.2s}
.kc:hover{transform:translateY(-2px);box-shadow:0 6px 20px rgba(0,0,0,.09)}
.kc::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:var(--ak,linear-gradient(90deg,#F6C453,#F2A900));border-radius:14px 14px 0 0}
.ki{width:32px;height:32px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:16px;margin-bottom:8px;background:var(--ib,#FFF3D6)}
.kn{font-size:22px;font-weight:700;line-height:1}
.kl{font-size:11px;color:#6B6B6B;margin-top:2px}
.kt{display:inline-block;font-size:10px;padding:2px 7px;border-radius:8px;margin-top:6px;font-weight:500}
.tg{background:#E9F7EC;color:#2E7D32}.tr{background:#FEE8E8;color:#C62828}.ty{background:#FFF3D6;color:#8B6200}.tb{background:#E3F2FD;color:#0D47A1}

/* ── Demographic 5-card row ── */
.demo-sec-hdr{margin:24px 0 12px}
.demo-row{display:grid;grid-template-columns:repeat(5,1fr);gap:14px;align-items:stretch}
.demo-card{background:#fff;border-radius:16px;padding:16px 14px 14px;box-shadow:0 4px 16px rgba(0,0,0,.07);position:relative;overflow:hidden;display:flex;flex-direction:column}
.demo-card::before{content:'';position:absolute;top:0;left:0;right:0;height:4px;background:var(--dc,#F6C453);border-radius:16px 16px 0 0}
.demo-title{font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:#A8A8A8;margin-bottom:14px}

/* Donut SVG */
.demo-donut-wrap{display:flex;justify-content:center;margin-bottom:10px}
.demo-donut-svg{width:110px;height:110px}
.donut-big{font-size:7px;font-weight:700;fill:#2E2E2E;text-anchor:middle;dominant-baseline:middle}
.donut-sub{font-size:3.2px;fill:#6B6B6B;text-anchor:middle;dominant-baseline:middle}

/* Legend rows */
.demo-legend{display:flex;flex-direction:column;gap:5px;border-top:1px solid #F7F0E8;padding-top:10px;flex:1;justify-content:space-evenly}
.demo-leg-row{display:flex;align-items:center;gap:7px;font-size:11.5px}
.demo-dot{width:9px;height:9px;border-radius:50%;flex-shrink:0}
.demo-leg-label{flex:1;color:#2E2E2E;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.demo-leg-val{font-weight:700;color:#2E2E2E;min-width:36px;text-align:right}
.demo-leg-pct{color:#A8A8A8;font-size:10.5px;min-width:30px;text-align:right}

/* Segmented bar (caste) */
.seg-bar-wrap{display:flex;height:20px;border-radius:10px;overflow:hidden;gap:2px;margin-top:6px}
.seg-bar-seg{height:100%;border-radius:0;transition:opacity .2s;cursor:default}
.seg-bar-seg:hover{opacity:.85}

/* Horizontal bar rows (edu/occ) */
.demo-bars-wrap{display:flex;flex-direction:column;gap:7px;padding-top:2px;flex:1;justify-content:space-evenly}
.demo-bar-row{display:flex;align-items:center;gap:7px}
.demo-bar-label{width:108px;flex-shrink:0;color:#5A5A5A;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;font-size:10.5px}
.demo-bar-track{flex:1;height:13px;background:#F7F0E8;border-radius:7px;overflow:hidden}
.demo-bar-fill{height:100%;border-radius:7px;transition:width .8s cubic-bezier(.4,0,.2,1)}
.demo-bar-num{font-weight:700;color:#2E2E2E;min-width:34px;text-align:right;font-size:11px;white-space:nowrap}
.demo-bar-pct{font-weight:400;color:#A8A8A8;font-size:10px}

@media(max-width:1200px){.demo-row{grid-template-columns:repeat(3,1fr)}}
@media(max-width:800px){.demo-row{grid-template-columns:repeat(2,1fr)}}
@media(max-width:500px){.demo-row{grid-template-columns:1fr}}

/* ── District panel ── */
.dist-hdr{display:flex;align-items:flex-start;justify-content:space-between;gap:16px;margin-bottom:18px;flex-wrap:wrap}
.dist-kpi-strip{display:flex;gap:10px;flex-wrap:wrap}
.dist-kpi{background:#fff;border:1px solid #F0E6D6;border-radius:12px;padding:10px 18px;text-align:center;min-width:90px;box-shadow:0 2px 8px rgba(0,0,0,.05)}
.dist-kpi span{display:block;font-size:22px;font-weight:700;color:#F2A900;line-height:1.1}
.dist-kpi{font-size:11px;color:#6B6B6B;margin-top:2px}
.dist-row-2{display:grid;grid-template-columns:1fr 280px;gap:14px;align-items:start}
.dist-card{background:#fff;border-radius:14px;padding:18px 20px;box-shadow:0 3px 12px rgba(0,0,0,.06)}
.dist-card-wide{}
.dist-card-narrow{}
.donut-legend{display:flex;gap:14px;justify-content:center;font-size:11px;color:#6B6B6B;margin-top:8px;flex-wrap:wrap}
.dl-dot{display:inline-block;width:10px;height:10px;border-radius:50%;margin-right:3px}
.dist-table-hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;gap:12px;flex-wrap:wrap}
.dist-search{border:1px solid #F0E6D6;border-radius:20px;padding:6px 14px;font-size:12px;outline:none;background:#FFFDF7;width:200px}
.dist-search:focus{border-color:#F6C453}
.dist-table-wrap{overflow-x:auto;overflow-y:auto;max-height:420px}
.dist-tbl{width:100%;border-collapse:collapse;font-size:12px}
.dist-tbl th{text-align:left;padding:8px 10px;font-size:10px;text-transform:uppercase;letter-spacing:.06em;color:#A8A8A8;border-bottom:2px solid #F0E6D6;white-space:nowrap;position:sticky;top:0;background:#fff;z-index:1;user-select:none}
.dist-tbl th.sortable:hover{color:#F2A900;background:#FFFDF7}
.dist-tbl th.sort-asc,.dist-tbl th.sort-desc{color:#F2A900}
.sort-icon{font-size:10px;opacity:.5;margin-left:3px}
.dist-tbl th.sort-asc .sort-icon,.dist-tbl th.sort-desc .sort-icon{opacity:1}
.dist-tbl td{padding:7px 10px;border-bottom:1px solid #F7F0E8;vertical-align:middle}
.dist-tbl tbody tr:hover{background:#FFFDF0}
.dist-rank{color:#A8A8A8;font-size:11px;width:28px}
.dist-name{font-weight:600;color:#2E2E2E}
.dist-num{text-align:right;font-variant-numeric:tabular-nums}
.nbb-bar-bg{position:relative;background:#F0E6D6;border-radius:6px;height:16px;min-width:80px;overflow:hidden}
.nbb-bar-fill{position:absolute;left:0;top:0;bottom:0;background:linear-gradient(90deg,#81C784,#43A047);border-radius:6px;transition:width .3s}
.nbb-bar-bg span{position:relative;z-index:1;font-size:10px;padding-left:6px;line-height:16px;font-weight:600;color:#2E2E2E}
.dist-mini-bar{display:flex;height:10px;border-radius:5px;overflow:hidden;min-width:80px;background:#F0E6D6}
.dmb-male{background:#F6C453;height:100%}
.dmb-female{background:#CE93D8;height:100%}
@media(max-width:900px){.dist-row-2{grid-template-columns:1fr}}
.g2{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:14px;margin-bottom:14px}
.g3{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:12px;margin-bottom:14px}
.g4{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:12px;margin-bottom:14px}
.cc{background:#fff;border-radius:14px;padding:18px;box-shadow:0 3px 12px rgba(0,0,0,.06)}
.ct{font-size:13px;font-weight:600;margin-bottom:2px}
.cs{font-size:10px;color:#6B6B6B;margin-bottom:12px}
.bars{display:flex;flex-direction:column;gap:8px}
.br{display:flex;align-items:center;gap:7px}
.bl{font-size:11px;color:#6B6B6B;width:110px;flex-shrink:0;text-align:right}
.bl.w90{width:90px}.bl.w130{width:130px}
.bt{flex:1;height:18px;background:#F7F0E4;border-radius:5px;overflow:hidden}
.bf{height:100%;border-radius:5px;display:flex;align-items:center;justify-content:flex-end;padding-right:6px;font-size:10px;font-weight:600;transition:width .8s cubic-bezier(.4,0,.2,1)}
.fg{background:linear-gradient(90deg,#81C784,#43A047);color:#fff}
.fa{background:linear-gradient(90deg,#FAD56C,#F2A900);color:#5C3D00}
.fb{background:linear-gradient(90deg,#64B5F6,#1976D2);color:#fff}
.fp{background:linear-gradient(90deg,#CE93D8,#7B1FA2);color:#fff}
.fc{background:linear-gradient(90deg,#FF8A65,#E64A19);color:#fff}
.ft{background:linear-gradient(90deg,#4DB6AC,#00796B);color:#fff}
.fr{background:linear-gradient(90deg,#EF9A9A,#C62828);color:#fff}
.dw{display:flex;align-items:center;gap:14px}
.leg{display:flex;flex-direction:column;gap:6px}
.lr{display:flex;align-items:center;gap:7px;font-size:11px;color:#2E2E2E}
.ld{width:9px;height:9px;border-radius:50%;flex-shrink:0}
.band{border-radius:16px;padding:20px;margin-bottom:14px}
.band-honey{background:linear-gradient(135deg,#FFF8E6,#FFF3D0,#FFF8E6);border:1px solid #F0E6D6}
.band-green{background:linear-gradient(135deg,#F1FAF2,#E9F7EC);border:1px solid #C8E6C9}
.band-eco{background:#FFF3D6;border:1px solid #F6D87A}
.band-loss{background:linear-gradient(135deg,#FFF5F5,#FEF0F0);border:1px solid #FFCDD2}
.band-blue{background:linear-gradient(135deg,#F0F7FF,#E8F1FF);border:1px solid #BBDEFB}
.band-purple{background:linear-gradient(135deg,#F8F0FF,#F3E5F5);border:1px solid #E1BEE7}
.ic{display:flex;gap:6px;flex-wrap:wrap;margin-top:10px}
.ip{padding:4px 10px;border-radius:16px;font-size:11px;font-weight:500}
.ig{background:#E9F7EC;color:#2E7D32;border:1px solid #C8E6C9}
.iy{background:#FFF3D6;color:#8B6200;border:1px solid #F6D87A}
.ib{background:#E3F2FD;color:#0D47A1;border:1px solid #BBDEFB}
.ir{background:#FEE8E8;color:#C62828;border:1px solid #FFCDD2}
.ip2{background:#F3E5F5;color:#4A148C;border:1px solid #E1BEE7}
.divr{height:1px;background:#F0E6D6;margin:14px 0}
.loss-g{display:grid;grid-template-columns:repeat(auto-fit,minmax(120px,1fr));gap:10px;margin-bottom:14px}
.lc{background:#fff;border-radius:12px;padding:12px;text-align:center;box-shadow:0 2px 8px rgba(0,0,0,.05)}
.lv{font-size:20px;font-weight:700}
.ll{font-size:10px;color:#6B6B6B;margin-top:2px}
.scheme-tbl{width:100%;border-collapse:collapse;font-size:11px}
.scheme-tbl th{padding:8px 10px;text-align:left;font-size:10px;text-transform:uppercase;letter-spacing:.06em;color:#6B6B6B;font-weight:600;background:#FFFDF7;border-bottom:1px solid #F0E6D6}
.scheme-tbl td{padding:8px 10px;border-bottom:1px solid #FAF6F0}
.scheme-tbl tr:hover td{background:#FFF8E6}
.pill{display:inline-block;padding:2px 7px;border-radius:7px;font-size:10px;font-weight:500}
.py2{background:#FFF3D6;color:#8B6200}.pg2{background:#E9F7EC;color:#2E7D32}.pb2{background:#E3F2FD;color:#0D47A1}.pr2{background:#FEE8E8;color:#C62828}.pp2{background:#F3E5F5;color:#4A148C}.pt2{background:#E0F2F1;color:#004D40}
.srch-wrap{display:flex;align-items:center;gap:8px;background:#fff;border:1px solid #F0E6D6;border-radius:10px;padding:7px 12px;margin-bottom:12px}
.srch-wrap input{border:none;background:none;outline:none;font-size:12px;color:#2E2E2E;flex:1;font-family:inherit}
.srch-wrap input::placeholder{color:#C0B8A8}
.var-tbl-wrap{background:#fff;border-radius:14px;overflow:hidden;box-shadow:0 3px 12px rgba(0,0,0,.06)}
.var-scroll{max-height:340px;overflow-y:auto;scrollbar-width:thin;scrollbar-color:#F0E6D6 transparent}
.var-tbl{width:100%;border-collapse:collapse;font-size:11px}
.var-tbl th{padding:8px 12px;text-align:left;font-size:10px;text-transform:uppercase;letter-spacing:.06em;color:#6B6B6B;font-weight:600;background:#FFFDF7;border-bottom:1px solid #F0E6D6;position:sticky;top:0}
.var-tbl td{padding:7px 12px;border-bottom:1px solid #FAF6F0;color:#2E2E2E}
.var-tbl tr:nth-child(even) td{background:#FFFDF7}
.var-tbl tr:hover td{background:#FFF8E6}

/* ── Land Use Panel v2 ── */

/* KPI strip */
.lu2-kpi-row{display:grid;grid-template-columns:repeat(6,1fr);gap:14px;margin-bottom:28px}
.lu2-kpi{background:#fff;border-radius:16px;padding:18px 16px 16px;box-shadow:0 2px 12px rgba(0,0,0,.06);border-left:4px solid var(--lc,#F2A900);display:flex;flex-direction:column;gap:3px}
.lu2-kpi-top{display:flex;align-items:center;gap:8px}
.lu2-kpi-ico{font-size:22px;line-height:1}
.lu2-kpi-val{font-size:26px;font-weight:800;color:#1E1E1E;line-height:1}
.lu2-kpi-lbl{font-size:11px;font-weight:700;color:#4A4A4A;text-transform:uppercase;letter-spacing:.07em;margin-top:2px}
.lu2-kpi-sub{font-size:11px;color:#A8A8A8}

/* 1×4 row grid */
.lu2-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px}
.lu2-card{background:#fff;border-radius:18px;padding:20px 20px 18px;box-shadow:0 4px 18px rgba(0,0,0,.07);border:1px solid #F0EBE3;border-top:5px solid var(--cc,#F2A900);display:flex;flex-direction:column;gap:16px}

/* Card header */
.lu2-card-hdr{display:flex;align-items:center;gap:10px}
.lu2-card-icon{font-size:32px;line-height:1;flex-shrink:0}
.lu2-card-titles{flex:1;min-width:0}
.lu2-card-name{font-size:15px;font-weight:800;color:#1E1E1E;line-height:1.2;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.lu2-card-hindi{font-size:11.5px;color:#8A8A8A;margin-top:1px}
.lu2-card-pill{background:var(--cc,#F2A900);color:#fff;font-size:10.5px;font-weight:700;padding:4px 10px;border-radius:20px;white-space:nowrap;flex-shrink:0;box-shadow:0 2px 6px rgba(0,0,0,.15)}

/* 4-stat grid (2×2) */
.lu2-stat-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.lu2-stat-box{background:#F8F6F2;border-radius:10px;padding:10px 12px;border-left:3px solid #E0D8CC}
.lu2-stat-n{font-size:18px;font-weight:800;color:#1E1E1E;line-height:1}
.lu2-stat-l{font-size:10px;color:#8A8A8A;margin-top:3px;font-weight:500}

/* Area scale bar */
.lu2-scale-wrap{display:flex;flex-direction:column;gap:5px}
.lu2-scale-label{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:#A8A8A8}
.lu2-scale-label span{font-weight:400;text-transform:none;letter-spacing:0}
.lu2-scale-track{height:9px;background:#F0EBE3;border-radius:4px;overflow:hidden}
.lu2-scale-fill{height:100%;border-radius:4px;transition:width .6s}
.lu2-scale-num{font-size:11px;font-weight:700;color:#4A4A4A}

/* Section micro-label */
.lu2-sec-label{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:#A8A8A8;margin-bottom:3px}

/* Irrigation split */
.lu2-irr-wrap{display:flex;flex-direction:column;gap:7px}
.lu2-irr-bar{display:flex;height:18px;border-radius:9px;overflow:hidden;gap:2px}
.lu2-irr-seg{height:100%;transition:width .5s}
.irr2{background:linear-gradient(90deg,#42A5F5,#1565C0)}
.non2{background:linear-gradient(90deg,#EF5350,#B71C1C)}
.lu2-irr-legend{display:flex;flex-direction:column;gap:4px}
.lu2-irr-leg-item{display:flex;align-items:center;gap:6px}
.lu2-irr-dot{width:9px;height:9px;border-radius:50%;flex-shrink:0}
.lu2-irr-pct{font-size:14px;font-weight:800;color:#1E1E1E;min-width:32px}
.lu2-irr-txt{font-size:11px;color:#6B6B6B;flex:1}
.lu2-irr-bigha{font-size:11px;font-weight:600;color:#A8A8A8}

/* Irrigation sources */
.lu2-src-wrap{display:flex;flex-direction:column;gap:7px;border-top:1px solid #F0E6D6;padding-top:14px}
.lu2-src-row{display:flex;align-items:center;gap:7px}
.lu2-src-dot{width:9px;height:9px;border-radius:50%;flex-shrink:0}
.lu2-src-name{flex:1;font-size:11px;color:#3A3A3A;font-weight:500;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.lu2-src-bar-wrap{width:50px;height:8px;background:#F0EBE3;border-radius:4px;overflow:hidden;flex-shrink:0}
.lu2-src-bar-fill{height:100%;border-radius:4px;transition:width .6s}
.lu2-src-pct{font-size:12px;font-weight:800;color:#1E1E1E;width:30px;text-align:right;flex-shrink:0}
.lu2-src-count{font-size:10.5px;color:#A8A8A8;flex-shrink:0}

/* Rent chip */
.lu2-rent{display:flex;align-items:center;gap:8px;background:var(--cl,#FFF8E6);border:1.5px solid var(--cc,#E89B00);border-radius:10px;padding:9px 14px;margin-top:auto}
.lu2-rent-ico{font-size:16px}
.lu2-rent-lbl{font-size:11px;color:#6B6B6B;flex:1}
.lu2-rent-val{font-size:13px;font-weight:800}

@media(max-width:1100px){.lu2-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:600px){.lu2-grid{grid-template-columns:1fr}.lu2-kpi-row{grid-template-columns:repeat(3,1fr)}}

/* ── Colonies Panel ── */
.col-kpi-row{display:grid;grid-template-columns:repeat(6,1fr);gap:14px;margin-bottom:22px}
.col-kpi{background:#fff;border-radius:14px;padding:16px 14px 14px;box-shadow:0 2px 10px rgba(0,0,0,.06);border-left:4px solid var(--ck,#F2A900);display:flex;flex-direction:column;gap:2px}
.col-kpi-ico{font-size:20px;margin-bottom:4px}
.col-kpi-val{font-size:22px;font-weight:800;color:#1E1E1E;line-height:1.1}
.col-kpi-lbl{font-size:10.5px;font-weight:700;color:#4A4A4A;text-transform:uppercase;letter-spacing:.06em;margin-top:2px}
.col-kpi-sub{font-size:10.5px;color:#A8A8A8}
.col-charts-row{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}
.col-chart-card{background:#fff;border-radius:18px;padding:22px 24px;box-shadow:0 3px 16px rgba(0,0,0,.06);border:1px solid #F0EBE3;display:flex;flex-direction:column;gap:16px}
.col-card-title{font-size:14px;font-weight:800;color:#1E1E1E}
.col-card-sub{font-size:11px;color:#A8A8A8;margin-top:-10px}
.col-bar-list{display:flex;flex-direction:column;gap:10px}
.col-bar-row{display:flex;align-items:center;gap:10px}
.col-bar-label{font-size:12px;color:#4A4A4A;width:120px;flex-shrink:0;font-weight:500}
.col-bar-track{flex:1;height:10px;background:#F0EBE3;border-radius:5px;overflow:hidden}
.col-bar-fill{height:100%;border-radius:5px;transition:width .5s}
.col-bar-meta{display:flex;align-items:center;gap:6px;flex-shrink:0;width:72px;justify-content:flex-end}
.col-bar-n{font-size:12px;font-weight:700;color:#1E1E1E}
.col-bar-pct{font-size:11px;color:#A8A8A8;min-width:30px;text-align:right}
.col-src-label{display:flex;align-items:center;gap:6px}
.col-src-dot{width:9px;height:9px;border-radius:50%;flex-shrink:0}
.col-stack-wrap{display:flex;flex-direction:column;gap:5px;margin-top:4px;padding-top:12px;border-top:1px solid #F0E6D6}
.col-stack-lbl{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:#A8A8A8}
.col-stack-bar{display:flex;height:14px;border-radius:7px;overflow:hidden;gap:2px}
.col-stack-seg{height:100%;transition:width .5s}
.col-avg-badge{display:flex;align-items:center;justify-content:space-between;background:#FFFDF7;border:1px solid #F0E6D6;border-radius:10px;padding:10px 16px;margin-top:auto}
.col-avg-lbl{font-size:11px;color:#6B6B6B;font-weight:500}
.col-avg-val{font-size:18px;font-weight:800;color:#F2A900}
.col-year-badges{display:flex;gap:8px;flex-wrap:wrap;margin-top:6px}
.col-year-badge{font-size:11px;font-weight:600;padding:4px 10px;border-radius:20px;border:1px solid;white-space:nowrap}
@media(max-width:1000px){.col-charts-row{grid-template-columns:1fr}.col-kpi-row{grid-template-columns:repeat(4,1fr) !important}}

/* ── Bee Colony Source Panel ── */
.bcs-overview{display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-bottom:22px}
.bcs-stack-card{background:#fff;border-radius:16px;padding:20px 24px;box-shadow:0 3px 14px rgba(0,0,0,.06);border:1px solid #F0EBE3;display:flex;flex-direction:column;gap:12px}
.bcs-stack-title{font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:#A8A8A8}
.bcs-stack-bar{display:flex;height:24px;border-radius:12px;overflow:hidden;gap:3px}
.bcs-stack-seg{height:100%;transition:width .6s}
.bcs-stack-legend{display:flex;gap:20px;flex-wrap:wrap}
.bcs-leg-item{display:flex;align-items:center;gap:6px;font-size:12px}
.bcs-leg-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0}
.bcs-leg-name{color:#4A4A4A;font-weight:600}
.bcs-leg-pct{font-weight:800}
.bcs-leg-n{color:#A8A8A8;font-size:11px}

/* 3-col type cards */
.bcs-cards{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}
.bcs-card{background:var(--bcl,#fff);border-radius:18px;padding:22px 22px 20px;box-shadow:0 3px 16px rgba(0,0,0,.07);border:1px solid #F0EBE3;border-top:5px solid var(--bcc,#1565C0);display:flex;flex-direction:column;gap:16px}
.bcs-card-hdr{display:flex;align-items:center;gap:12px}
.bcs-card-ico{font-size:34px;line-height:1;flex-shrink:0}
.bcs-card-titles{flex:1}
.bcs-card-name{font-size:16px;font-weight:800;color:#1E1E1E}
.bcs-card-hindi{font-size:12px;color:#8A8A8A;margin-top:1px}
.bcs-card-pill{color:#fff;font-size:11px;font-weight:700;padding:4px 12px;border-radius:20px;white-space:nowrap;flex-shrink:0}
.bcs-share-wrap{display:flex;flex-direction:column;gap:5px}
.bcs-share-track{height:9px;background:#E8E0D8;border-radius:5px;overflow:hidden}
.bcs-share-fill{height:100%;border-radius:5px;transition:width .6s}
.bcs-share-pct{font-size:11px;font-weight:700}
.bcs-stat-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.bcs-stat{background:#fff;border-radius:10px;padding:12px 14px;border-left:3px solid #E0D8CC}
.bcs-stat-n{font-size:18px;font-weight:800;color:#1E1E1E;line-height:1}
.bcs-stat-l{font-size:10px;color:#8A8A8A;margin-top:3px}
.bcs-src-wrap{display:flex;flex-direction:column;gap:7px;border-top:1px solid #E8E0D8;padding-top:14px}
.bcs-src-title{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:#A8A8A8;margin-bottom:2px}
.bcs-src-row{display:flex;align-items:center;gap:7px}
.bcs-src-dot{width:9px;height:9px;border-radius:50%;flex-shrink:0}
.bcs-src-name{flex:1;font-size:11px;color:#3A3A3A;font-weight:500;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.bcs-src-track{width:55px;height:8px;background:#F0EBE3;border-radius:4px;overflow:hidden;flex-shrink:0}
.bcs-src-fill{height:100%;border-radius:4px;transition:width .5s}
.bcs-src-pct{font-size:12px;font-weight:800;color:#1E1E1E;width:28px;text-align:right;flex-shrink:0}
.bcs-src-n{font-size:10.5px;color:#A8A8A8;flex-shrink:0}
@media(max-width:1000px){.bcs-cards{grid-template-columns:1fr}.bcs-overview{grid-template-columns:1fr}}

/* ── BK Operations (Section 7) ── */
.bko-kpi-row{display:grid;grid-template-columns:repeat(5,1fr);gap:12px;margin-bottom:20px}
.bko-kpi{background:#fff;border-radius:12px;padding:16px 18px;box-shadow:0 2px 10px rgba(0,0,0,.06);border-top:4px solid var(--kc,#F2A900);display:flex;flex-direction:column;gap:3px}
.bko-kpi-val{font-size:26px;font-weight:800;color:var(--kc,#1E1E1E);line-height:1}
.bko-kpi-lbl{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:#4A4A4A;margin-top:2px}
.bko-kpi-sub{font-size:10.5px;color:#A0A0A0}

.bko-charts{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
.bko-chart-card{background:#fff;border-radius:14px;padding:22px 22px 18px;box-shadow:0 2px 12px rgba(0,0,0,.07);border:1px solid #F0EBE3;display:flex;flex-direction:column;gap:0}
.bko-card-title{font-size:14px;font-weight:700;color:#1E1E1E;margin-bottom:3px}
.bko-card-sub{font-size:11px;color:#A0A0A0;margin-bottom:16px}

.bko-bar-row{display:flex;align-items:center;gap:10px;margin-bottom:11px}
.bko-bar-row--sm{margin-bottom:9px}
.bko-bar-label{display:flex;flex-direction:column;width:130px;flex-shrink:0}
.bko-bar-label--sm{width:110px}
.bko-bar-name{font-size:12px;font-weight:600;color:#2E2E2E;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.bko-bar-hindi{font-size:10px;color:#A0A0A0;margin-top:1px}
.bko-bar-track{flex:1;height:12px;background:#F0EBE3;border-radius:6px;overflow:hidden}
.bko-bar-fill{height:100%;border-radius:6px;transition:width .5s}
.bko-bar-meta{display:flex;flex-direction:column;align-items:flex-end;width:44px;flex-shrink:0}
.bko-bar-pct{font-size:13px;font-weight:800;line-height:1}
.bko-bar-n{font-size:10px;color:#A0A0A0;white-space:nowrap}
.bko-total-row{font-size:10.5px;color:#B0A898;margin-top:4px;text-align:right}

.bko-mig-split-wrap{margin-bottom:14px}
.bko-mig-split{height:18px;border-radius:9px;overflow:hidden;display:flex;margin-bottom:8px}
.bko-mig-seg{height:100%;transition:width .5s}
.bko-mig-leg{display:flex;gap:16px}
.bko-mig-leg-item{display:flex;align-items:center;gap:5px;font-size:12px;color:#4A4A4A}
.bko-mig-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0}
.bko-mig-n{font-size:10.5px;color:#A0A0A0}
.bko-sub-hdr{font-size:10.5px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:#A0A0A0;margin-bottom:10px;margin-top:2px;padding-top:12px;border-top:1px solid #F0EBE3}
.bko-avg-chip{display:inline-block;margin-top:10px;font-size:12px;font-weight:700;padding:5px 12px;border-radius:20px}

.bko-hist-row{display:flex;align-items:center;gap:10px;margin-bottom:10px}
.bko-hist-lbl{width:74px;font-size:11.5px;font-weight:600;color:#2E2E2E;flex-shrink:0}
.bko-hist-track{flex:1;height:22px;background:#FFF8E1;border-radius:5px;overflow:hidden}
.bko-hist-fill{height:100%;border-radius:5px;transition:width .5s}
.bko-hist-meta{display:flex;flex-direction:column;align-items:flex-end;width:40px;flex-shrink:0}
.bko-hist-pct{font-size:12px;font-weight:800;color:#1E1E1E;line-height:1}
.bko-hist-n{font-size:9.5px;color:#A0A0A0}
.bko-honey-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-top:8px;padding-top:12px;border-top:1px solid #F0EBE3}
.bko-hstat{text-align:center;padding:8px 4px;border-top:3px solid #E0E0E0}
.bko-hstat-v{font-size:17px;font-weight:800;color:#1E1E1E;line-height:1}
.bko-hstat-l{font-size:9.5px;text-transform:uppercase;letter-spacing:.06em;color:#A0A0A0;margin-top:3px}
@media(max-width:1000px){.bko-charts{grid-template-columns:1fr}.bko-kpi-row{grid-template-columns:repeat(2,1fr)}}

/* ── BK Production (Section 8) ── */
.bkp-kpi-row{display:grid;grid-template-columns:repeat(6,1fr);gap:12px;margin-bottom:20px}
.bkp-kpi{background:#fff;border-radius:12px;padding:15px 16px;box-shadow:0 2px 10px rgba(0,0,0,.06);border-top:4px solid var(--kc,#F2A900);display:flex;flex-direction:column;gap:3px}
.bkp-kpi-val{font-size:20px;font-weight:800;color:var(--kc,#1E1E1E);line-height:1}
.bkp-kpi-lbl{font-size:10.5px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:#4A4A4A;margin-top:2px}
.bkp-kpi-sub{font-size:10px;color:#A0A0A0}

.bkp-charts{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
.bkp-chart-card{background:#fff;border-radius:14px;padding:22px 22px 18px;box-shadow:0 2px 12px rgba(0,0,0,.07);border:1px solid #F0EBE3;display:flex;flex-direction:column;gap:0}
.bkp-card-title{font-size:14px;font-weight:700;color:#1E1E1E;margin-bottom:3px}
.bkp-card-sub{font-size:11px;color:#A0A0A0;margin-bottom:16px}

.bkp-bar-row{display:flex;align-items:center;gap:10px;margin-bottom:11px;flex-wrap:wrap}
.bkp-bar-label{width:120px;font-size:12px;font-weight:600;color:#2E2E2E;flex-shrink:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.bkp-bar-track{flex:1;min-width:60px;height:13px;background:#F0EBE3;border-radius:6px;overflow:hidden}
.bkp-bar-fill{height:100%;border-radius:6px;transition:width .5s}
.bkp-bar-meta{display:flex;flex-direction:column;align-items:flex-end;width:44px;flex-shrink:0}
.bkp-bar-pct{font-size:13px;font-weight:800;line-height:1}
.bkp-bar-n{font-size:10px;color:#A0A0A0;white-space:nowrap}
.bkp-note{font-size:10px;color:#B0A898;margin-top:4px;font-style:italic}

.bkp-honey-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:16px}
.bkp-hstat{text-align:center;padding:10px 6px;border-radius:10px;background:#FFFDF7;border-top:3px solid var(--hc,#F2A900)}
.bkp-hstat-v{font-size:16px;font-weight:800;color:#1E1E1E;line-height:1}
.bkp-hstat-l{font-size:9px;text-transform:uppercase;letter-spacing:.06em;color:#A0A0A0;margin-top:3px}

.bkp-sub-hdr{font-size:10.5px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:#A0A0A0;margin-bottom:10px;padding-top:12px;border-top:1px solid #F0EBE3}
.bkp-big-stat{font-size:22px;font-weight:800;line-height:1.2;margin-top:6px}
.bkp-big-stat span{font-size:11px;font-weight:500;color:#6A6A6A;display:block;margin-top:3px}

.bkp-bp-row{display:flex;align-items:center;gap:8px;margin-bottom:12px;flex-wrap:wrap}
.bkp-bp-label{display:flex;flex-direction:column;width:110px;flex-shrink:0}
.bkp-bp-name{font-size:12px;font-weight:700}
.bkp-bp-hindi{font-size:10px;color:#A0A0A0;margin-top:1px}
.bkp-bp-meta{display:flex;flex-direction:column;align-items:flex-end;width:44px;flex-shrink:0}
.bkp-bp-chips{display:flex;gap:5px;width:100%;padding-left:118px;flex-wrap:wrap;margin-top:-6px;margin-bottom:4px}
.bkp-bp-chip{font-size:9.5px;background:#F4F4F4;border-radius:10px;padding:2px 7px;color:#555;white-space:nowrap}
@media(max-width:1000px){.bkp-charts{grid-template-columns:1fr}.bkp-kpi-row{grid-template-columns:repeat(3,1fr)}}

/* ── BK Costs (Section 9) ── */
.bkc-kpi-row{display:grid;grid-template-columns:repeat(6,1fr);gap:12px;margin-bottom:20px}
.bkc-kpi{background:#fff;border-radius:12px;padding:15px 16px;box-shadow:0 2px 10px rgba(0,0,0,.06);border-top:4px solid var(--kc,#00695C);display:flex;flex-direction:column;gap:3px}
.bkc-kpi-val{font-size:20px;font-weight:800;color:var(--kc,#1E1E1E);line-height:1}
.bkc-kpi-lbl{font-size:10.5px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:#4A4A4A;margin-top:2px}
.bkc-kpi-sub{font-size:10px;color:#A0A0A0}

.bkc-charts{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
.bkc-chart-card{background:#fff;border-radius:14px;padding:22px 22px 18px;box-shadow:0 2px 12px rgba(0,0,0,.07);border:1px solid #F0EBE3;display:flex;flex-direction:column;gap:0}
.bkc-card-title{font-size:14px;font-weight:700;color:#1E1E1E;margin-bottom:3px}
.bkc-card-sub{font-size:11px;color:#A0A0A0;margin-bottom:14px}
.bkc-sub-hdr{font-size:10.5px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:#A0A0A0;margin-bottom:10px;padding-top:12px;border-top:1px solid #F0EBE3}

/* Capital split bar */
.bkc-cap-split-wrap{margin-bottom:14px}
.bkc-cap-split{height:18px;border-radius:9px;overflow:hidden;display:flex;margin-bottom:8px}
.bkc-cap-seg{height:100%;transition:width .5s}
.bkc-cap-leg{display:flex;flex-direction:column;gap:6px}
.bkc-cap-leg-item{display:flex;align-items:center;gap:6px;font-size:12px;color:#4A4A4A}
.bkc-cap-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0}
.bkc-cap-sub{font-size:10.5px;color:#A0A0A0;margin-left:auto}

/* Fixed cost grid */
.bkc-fc-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px}
.bkc-fc-stat{text-align:center;padding:9px 4px;border-radius:10px;background:#FFFDF7;border-top:3px solid var(--fcc,#00695C)}
.bkc-fc-val{font-size:14px;font-weight:800;color:#1E1E1E;line-height:1}
.bkc-fc-lbl{font-size:9px;text-transform:uppercase;letter-spacing:.06em;color:#A0A0A0;margin-top:3px}

/* Variable cost rows */
.bkc-vc-row{display:flex;align-items:center;gap:8px;margin-bottom:8px}
.bkc-vc-label{width:120px;font-size:11.5px;font-weight:600;color:#2E2E2E;flex-shrink:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.bkc-bar-track{flex:1;height:12px;background:#F0EBE3;border-radius:6px;overflow:hidden}
.bkc-bar-fill{height:100%;border-radius:6px;transition:width .5s}
.bkc-vc-meta{display:flex;flex-direction:column;align-items:flex-end;width:60px;flex-shrink:0}
.bkc-vc-amt{font-size:11px;font-weight:700;line-height:1;white-space:nowrap}
.bkc-vc-share{font-size:9.5px;color:#A0A0A0}
.bkc-vc-total{font-size:11px;color:#4A4A4A;margin-top:8px;padding-top:10px;border-top:1px solid #F0EBE3;text-align:right}
.bkc-vc-total strong{color:#1E1E1E}

/* Labour cards */
.bkc-labour-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px}
.bkc-lab-card{background:#FFFDF7;border-radius:10px;padding:10px 8px;text-align:center;border-top:3px solid var(--lc,#1E1E1E)}
.bkc-lab-ico{font-size:18px;line-height:1;margin-bottom:4px}
.bkc-lab-type{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:#6A6A6A;margin-bottom:4px}
.bkc-lab-val{font-size:22px;font-weight:800;color:var(--lc,#1E1E1E);line-height:1}
.bkc-lab-lbl{font-size:9.5px;color:#A0A0A0;margin-bottom:6px}
.bkc-lab-chip{font-size:9px;background:#F4F4F4;border-radius:8px;padding:3px 6px;color:#555;display:block;margin-top:4px;word-break:break-word}

/* Profit bar */
.bkc-profit-wrap{margin-top:4px}
.bkc-profit-bar-wrap{display:flex;align-items:center;gap:8px;margin-bottom:10px}
.bkc-profit-label{font-size:10px;color:#6A6A6A;flex-shrink:0;width:70px}
.bkc-profit-label:last-child{text-align:right}
.bkc-profit-track{flex:1;height:20px;border-radius:10px;overflow:hidden;display:flex}
.bkc-profit-cost{background:#C62828;height:100%;transition:width .5s}
.bkc-profit-gain{background:#2E7D32;height:100%;transition:width .5s}
.bkc-profit-stats{display:flex;flex-direction:column;gap:6px}
.bkc-ps-item{display:flex;align-items:center;gap:7px;font-size:12px;color:#4A4A4A}
.bkc-ps-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0}
.bkc-ps-item strong{margin-left:auto;font-size:13px}
@media(max-width:1000px){.bkc-charts{grid-template-columns:1fr}.bkc-kpi-row{grid-template-columns:repeat(3,1fr)}}

/* ── BK Losses (Section 10) ── */
.bkl-kpi-row{display:grid;grid-template-columns:repeat(5,1fr);gap:12px;margin-bottom:20px}
.bkl-kpi{background:#fff;border-radius:12px;padding:15px 16px;box-shadow:0 2px 10px rgba(0,0,0,.06);border-top:4px solid var(--kc,#B71C1C);display:flex;flex-direction:column;gap:3px}
.bkl-kpi-val{font-size:22px;font-weight:800;color:var(--kc,#1E1E1E);line-height:1}
.bkl-kpi-lbl{font-size:10.5px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:#4A4A4A;margin-top:2px}
.bkl-kpi-sub{font-size:10px;color:#A0A0A0}

.bkl-charts{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
.bkl-chart-card{background:#fff;border-radius:14px;padding:22px 22px 18px;box-shadow:0 2px 12px rgba(0,0,0,.07);border:1px solid #F0EBE3;display:flex;flex-direction:column;gap:0}
.bkl-card-title{font-size:14px;font-weight:700;color:#1E1E1E;margin-bottom:3px}
.bkl-card-sub{font-size:11px;color:#A0A0A0;margin-bottom:16px}
.bkl-sub-hdr{font-size:10.5px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:#A0A0A0;margin-bottom:10px;padding-top:12px;border-top:1px solid #F0EBE3}

.bkl-loss-row{display:flex;align-items:center;gap:8px;margin-bottom:12px}
.bkl-loss-label{display:flex;flex-direction:column;width:130px;flex-shrink:0}
.bkl-loss-name{font-size:12px;font-weight:600;color:#2E2E2E;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.bkl-loss-hindi{font-size:9.5px;color:#A0A0A0;margin-top:1px}
.bkl-bar-track{flex:1;height:13px;background:#F7EEE8;border-radius:6px;overflow:hidden}
.bkl-bar-fill{height:100%;border-radius:6px;transition:width .5s}
.bkl-loss-meta{display:flex;flex-direction:column;align-items:flex-end;width:46px;flex-shrink:0}
.bkl-loss-avg{font-size:12px;font-weight:800;line-height:1}
.bkl-loss-n{font-size:9.5px;color:#A0A0A0}
.bkl-total-chip{font-size:11px;margin-top:10px;padding:7px 12px;border-radius:10px;font-weight:500;line-height:1.5}
.bkl-total-chip strong{font-weight:800}

/* Loss composition bar */
.bkl-comp-bar{height:16px;border-radius:8px;overflow:hidden;display:flex;margin-bottom:8px}
.bkl-comp-seg{height:100%;transition:width .5s}
.bkl-comp-leg,.bkl-prod-leg{display:flex;flex-direction:column;gap:5px;margin-bottom:4px}
.bkl-cleg-item{display:flex;align-items:center;gap:6px;font-size:11.5px;color:#4A4A4A}
.bkl-cleg-dot{width:9px;height:9px;border-radius:50%;flex-shrink:0}
.bkl-cleg-kg{font-size:10px;color:#A0A0A0;margin-left:2px}
.bkl-cleg-item strong{margin-left:auto;font-size:12px}

/* Production vs loss bar */
.bkl-prod-bar{height:16px;border-radius:8px;overflow:hidden;display:flex;background:#EEE;margin-bottom:8px}
.bkl-prod-saved{background:#2E7D32;height:100%;transition:width .5s}
.bkl-prod-lost{background:#B71C1C;height:100%;transition:width .5s}

/* Survey totals grid */
.bkl-totals-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px}
.bkl-tot{text-align:center;padding:9px 4px;border-radius:10px;background:#FFFDF7;border-top:3px solid var(--tc,#B71C1C)}
.bkl-tot-v{font-size:15px;font-weight:800;color:#1E1E1E;line-height:1}
.bkl-tot-l{font-size:9px;text-transform:uppercase;letter-spacing:.06em;color:#A0A0A0;margin-top:3px}
@media(max-width:1000px){.bkl-charts{grid-template-columns:1fr}.bkl-kpi-row{grid-template-columns:repeat(3,1fr)}}

/* ── BK Empty + Protection (Sections 11 & 12) ── */
.bkep-kpi-row{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:20px}
.bkep-kpi{background:#fff;border-radius:12px;padding:16px 18px;box-shadow:0 2px 10px rgba(0,0,0,.06);border-top:4px solid var(--kc,#1565C0);display:flex;flex-direction:column;gap:3px}
.bkep-kpi-val{font-size:26px;font-weight:800;color:var(--kc,#1E1E1E);line-height:1}
.bkep-kpi-lbl{font-size:10.5px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:#4A4A4A;margin-top:2px}
.bkep-kpi-sub{font-size:10px;color:#A0A0A0}

.bkep-charts{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.bkep-chart-card{background:#fff;border-radius:14px;padding:22px 22px 18px;box-shadow:0 2px 12px rgba(0,0,0,.07);border:1px solid #F0EBE3;display:flex;flex-direction:column;gap:0}
.bkep-card-title{font-size:14px;font-weight:700;color:#1E1E1E;margin-bottom:3px}
.bkep-card-sub{font-size:11px;color:#A0A0A0;margin-bottom:14px}
.bkep-sub-hdr{font-size:10.5px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:#A0A0A0;margin-bottom:10px;padding-top:12px;border-top:1px solid #F0EBE3}

.bkep-yn-wrap{margin-bottom:4px}
.bkep-yn-bar{height:18px;border-radius:9px;overflow:hidden;display:flex;margin-bottom:8px}
.bkep-yn-seg{height:100%;transition:width .5s}
.bkep-yn-leg{display:flex;gap:16px;margin-bottom:4px}
.bkep-yn-item{display:flex;align-items:center;gap:5px;font-size:12px;color:#4A4A4A}
.bkep-yn-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0}
.bkep-yn-n{font-size:10.5px;color:#A0A0A0}

.bkep-bar-row{display:flex;align-items:center;gap:10px;margin-bottom:11px}
.bkep-bar-label{width:110px;font-size:12px;font-weight:600;color:#2E2E2E;flex-shrink:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.bkep-bar-track{flex:1;height:13px;background:#F0EBE3;border-radius:6px;overflow:hidden}
.bkep-bar-fill{height:100%;border-radius:6px;transition:width .5s}
.bkep-bar-meta{display:flex;flex-direction:column;align-items:flex-end;width:44px;flex-shrink:0}
.bkep-bar-pct{font-size:13px;font-weight:800;line-height:1}
.bkep-bar-n{font-size:10px;color:#A0A0A0}
.bkep-note{font-size:10px;color:#B0A898;font-style:italic;margin-top:4px}
@media(max-width:1000px){.bkep-charts{grid-template-columns:1fr}}

/* ── BK Selling (Section 13) ── */
.bks-trend-row{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:20px}
.bks-trend-card{background:#fff;border-radius:12px;padding:16px 20px;box-shadow:0 2px 10px rgba(0,0,0,.06);border-left:5px solid #F2A900}
.bks-trend-year{font-size:13px;font-weight:800;text-transform:uppercase;letter-spacing:.1em;color:#F57F17;margin-bottom:4px}
.bks-trend-out{font-size:22px;font-weight:800;color:#1E1E1E;line-height:1.2}
.bks-trend-out span{font-size:11px;font-weight:500;color:#A0A0A0}
.bks-trend-bar-wrap{height:8px;background:#FFF3E0;border-radius:4px;overflow:hidden;margin:10px 0 6px}
.bks-trend-bar{height:100%;background:linear-gradient(90deg,#FFD54F,#F2A900);border-radius:4px;transition:width .5s}
.bks-trend-meta{display:flex;justify-content:space-between;font-size:11px;color:#A0A0A0}
.bks-trend-pct{font-weight:700;color:#F57F17}

.bks-charts{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
.bks-chart-card{background:#fff;border-radius:14px;padding:20px 20px 16px;box-shadow:0 2px 12px rgba(0,0,0,.07);border:1px solid #F0EBE3}
.bks-card-hdr{display:flex;align-items:baseline;gap:10px;margin-bottom:12px}
.bks-card-year{font-size:20px;font-weight:800;color:#F57F17}
.bks-card-out{font-size:13px;font-weight:700;color:#1E1E1E}
.bks-card-n{font-size:11px;color:#A0A0A0;margin-left:auto}

.bks-stack-bar{height:20px;border-radius:10px;overflow:hidden;display:flex;margin-bottom:14px;background:#F0EBE3}
.bks-stack-seg{height:100%;transition:width .5s}

.bks-channels{display:flex;flex-direction:column;gap:10px}
.bks-ch-row{display:flex;align-items:center;gap:8px}
.bks-ch-dot{width:9px;height:9px;border-radius:50%;flex-shrink:0}
.bks-ch-info{display:flex;flex-direction:column;width:130px;flex-shrink:0}
.bks-ch-name{font-size:11.5px;font-weight:600;color:#2E2E2E;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.bks-ch-hindi{font-size:9.5px;color:#B0A898}
.bks-ch-bar-wrap{flex:1;height:10px;background:#F4F0EB;border-radius:5px;overflow:hidden}
.bks-ch-bar{height:100%;border-radius:5px;transition:width .5s}
.bks-ch-qty{font-size:12px;font-weight:800;width:36px;text-align:right;flex-shrink:0}
.bks-ch-price{font-size:10px;color:#A0A0A0;width:52px;text-align:right;flex-shrink:0;white-space:nowrap}

.bks-legend{display:flex;gap:18px;flex-wrap:wrap;margin-top:14px;padding-top:12px;border-top:1px solid #F4EEE6}
.bks-leg-item{display:flex;align-items:center;gap:6px;font-size:11.5px;color:#5A5A5A}
.bks-leg-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0}
@media(max-width:1000px){.bks-charts{grid-template-columns:1fr}.bks-trend-row{grid-template-columns:1fr}}

/* ── BK Co-Products (Section 14) ── */
.bkcp-overview{display:grid;grid-template-columns:repeat(5,1fr);gap:12px;margin-bottom:20px}
.bkcp-prod-card{background:#fff;border-radius:12px;padding:14px 14px 12px;box-shadow:0 2px 10px rgba(0,0,0,.06);border-top:4px solid var(--pcc,#F2A900)}
.bkcp-prod-ico{font-size:22px;margin-bottom:6px;line-height:1}
.bkcp-prod-name{font-size:13px;font-weight:800;color:#1E1E1E}
.bkcp-prod-hindi{font-size:10px;color:#A0A0A0;margin-bottom:8px}
.bkcp-prod-farmers{display:grid;grid-template-columns:auto 1fr;gap:2px 6px;align-items:center;margin-bottom:6px}
.bkcp-yr{font-size:9.5px;text-transform:uppercase;letter-spacing:.06em;color:#A0A0A0}
.bkcp-prod-farmers strong{font-size:12px;font-weight:800;color:#1E1E1E}
.bkcp-prod-meta{font-size:10px;color:#6A6A6A;margin-bottom:4px}
.bkcp-prod-meta.bkcp-nil{color:#C0B8B0;font-style:italic}
.bkcp-price-trend{font-size:10.5px;font-weight:700}

.bkcp-charts{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.bkcp-chart-card{background:#fff;border-radius:14px;padding:20px 22px 18px;box-shadow:0 2px 12px rgba(0,0,0,.07);border:1px solid #F0EBE3}
.bkcp-card-hdr{display:flex;align-items:flex-start;gap:10px;margin-bottom:14px}
.bkcp-card-ico{font-size:26px;flex-shrink:0;margin-top:2px}
.bkcp-card-title{font-size:14px;font-weight:700;color:#1E1E1E}
.bkcp-card-sub{font-size:11px;color:#A0A0A0;margin-top:2px}
.bkcp-sub-hdr{font-size:10.5px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:#A0A0A0;margin-bottom:10px;margin-top:14px;padding-top:12px;border-top:1px solid #F0EBE3}

.bkcp-year-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}
.bkcp-yr-stat{background:#FFFDF7;border-radius:10px;padding:10px 10px 8px}
.bkcp-yr-label{font-size:13px;font-weight:800;color:#F57F17;margin-bottom:2px}
.bkcp-yr-n{font-size:10px;color:#6A6A6A;margin-bottom:2px}
.bkcp-yr-out{font-size:11px;font-weight:600;color:#1E1E1E;margin-bottom:6px}
.bkcp-price-bar-wrap{height:8px;background:#F4EEE6;border-radius:4px;overflow:hidden;margin-bottom:4px}
.bkcp-price-bar{height:100%;border-radius:4px;transition:width .5s}
.bkcp-yr-price{font-size:13px;font-weight:800}

.bkcp-ch-row{display:flex;align-items:center;gap:8px;margin-bottom:9px}
.bkcp-ch-dot{width:9px;height:9px;border-radius:50%;flex-shrink:0}
.bkcp-ch-name{width:120px;font-size:12px;font-weight:600;color:#2E2E2E;flex-shrink:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.bkcp-ch-track{flex:1;height:12px;background:#F4EEE6;border-radius:6px;overflow:hidden}
.bkcp-ch-fill{height:100%;border-radius:6px;transition:width .5s}
.bkcp-ch-pct{font-size:12px;font-weight:800;width:36px;text-align:right;flex-shrink:0}
.bkcp-minor-note{font-size:10.5px;color:#A0A0A0;font-style:italic;margin-top:12px;padding-top:10px;border-top:1px solid #F0EBE3}
@media(max-width:1000px){.bkcp-overview{grid-template-columns:repeat(2,1fr)}.bkcp-charts{grid-template-columns:1fr}}

/* ── BK Grading & Branding (Section 15) ── */
.bkg-kpi-row{display:grid;grid-template-columns:repeat(5,1fr);gap:12px;margin-bottom:20px}
.bkg-kpi{background:#fff;border-radius:12px;padding:15px 16px;box-shadow:0 2px 10px rgba(0,0,0,.06);border-top:4px solid var(--kc,#6A1B9A);display:flex;flex-direction:column;gap:3px}
.bkg-kpi-val{font-size:22px;font-weight:800;color:var(--kc,#1E1E1E);line-height:1}
.bkg-kpi-lbl{font-size:10.5px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:#4A4A4A;margin-top:2px}
.bkg-kpi-sub{font-size:10px;color:#A0A0A0}

.bkg-charts{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
.bkg-chart-card{background:#fff;border-radius:14px;padding:20px 22px 18px;box-shadow:0 2px 12px rgba(0,0,0,.07);border:1px solid #F0EBE3;display:flex;flex-direction:column;gap:0}
.bkg-card-title{font-size:14px;font-weight:700;color:#1E1E1E;margin-bottom:3px}
.bkg-card-sub{font-size:11px;color:#A0A0A0;margin-bottom:12px}
.bkg-sub-hdr{font-size:10.5px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:#A0A0A0;margin-bottom:10px;padding-top:12px;border-top:1px solid #F0EBE3}

.bkg-yn-bar{height:16px;border-radius:8px;overflow:hidden;display:flex;margin-bottom:8px}
.bkg-yn-seg{height:100%;transition:width .5s}
.bkg-yn-leg{display:flex;align-items:center;gap:5px;font-size:11.5px;color:#4A4A4A;margin-bottom:4px;flex-wrap:wrap}
.bkg-yn-dot{width:9px;height:9px;border-radius:50%;flex-shrink:0}
.bkg-yn-n{font-size:10px;color:#A0A0A0}

.bkg-bar-row{display:flex;align-items:center;gap:8px;margin-bottom:10px}
.bkg-bar-row--sm{margin-bottom:8px}
.bkg-bar-label{display:flex;flex-direction:column;width:120px;flex-shrink:0}
.bkg-bar-label--sm{width:120px;flex-direction:row;align-items:center}
.bkg-bar-name{font-size:12px;font-weight:600;color:#2E2E2E;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.bkg-bar-hindi{font-size:9.5px;color:#A0A0A0;margin-top:1px}
.bkg-bar-track{flex:1;height:12px;background:#F0EBE3;border-radius:6px;overflow:hidden}
.bkg-bar-fill{height:100%;border-radius:6px;transition:width .5s}
.bkg-bar-meta{display:flex;flex-direction:column;align-items:flex-end;width:44px;flex-shrink:0}
.bkg-bar-pct{font-size:12px;font-weight:800;line-height:1}
.bkg-bar-n{font-size:9.5px;color:#A0A0A0;white-space:nowrap}

.bkg-brand-card{background:#FFFDF7;border-radius:10px;padding:11px 12px;margin-bottom:10px;border-left:4px solid var(--bc,#F2A900)}
.bkg-brand-hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:6px}
.bkg-brand-label{font-size:12.5px;font-weight:700;color:#1E1E1E}
.bkg-brand-n{font-size:10px;font-weight:700;color:#fff;padding:2px 8px;border-radius:10px}
.bkg-brand-bar-wrap{height:8px;background:#F0EBE3;border-radius:4px;overflow:hidden;margin-bottom:8px}
.bkg-brand-bar{height:100%;border-radius:4px;transition:width .5s}
.bkg-brand-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:4px}
.bkg-brand-stat{text-align:center}
.bkg-bs-v{display:block;font-size:12px;font-weight:800;color:#1E1E1E;white-space:nowrap}
.bkg-bs-l{display:block;font-size:9px;color:#A0A0A0;text-transform:uppercase;letter-spacing:.05em}
.bkg-note{font-size:10px;color:#B0A898;font-style:italic;margin-top:4px}

.bkg-col-row{display:flex;align-items:center;gap:10px;margin-bottom:14px}
.bkg-col-swatch{width:32px;height:32px;border-radius:8px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:14px}
.bkg-col-info{display:flex;flex-direction:column;width:100px;flex-shrink:0}
.bkg-col-name{font-size:12px;font-weight:600;color:#2E2E2E}
.bkg-col-hindi{font-size:9.5px;color:#A0A0A0}
.bkg-col-meta{display:flex;flex-direction:column;align-items:flex-end;width:68px;flex-shrink:0}
.bkg-col-n{font-size:11px;font-weight:700;color:#1E1E1E;white-space:nowrap}
.bkg-col-p{font-size:9.5px;color:#A0A0A0;white-space:nowrap}
@media(max-width:1000px){.bkg-charts{grid-template-columns:1fr}.bkg-kpi-row{grid-template-columns:repeat(3,1fr)}}

/* ── BK Training (Section 16) ── */
.bkt-kpi-row{display:grid;grid-template-columns:repeat(5,1fr);gap:12px;margin-bottom:20px}
.bkt-kpi-card{background:#fff;border-radius:12px;padding:16px 14px;border-top:3px solid var(--kc,#2E7D32);box-shadow:0 1px 4px rgba(0,0,0,.06)}
.bkt-kv{font-size:22px;font-weight:800;color:#1E1E1E;line-height:1}
.bkt-kp{font-size:11px;font-weight:700;color:var(--kc,#2E7D32);margin-top:3px}
.bkt-kl{font-size:10px;font-weight:600;color:#3E3E3E;margin-top:6px;text-transform:uppercase;letter-spacing:.04em}
.bkt-kh{font-size:9.5px;color:#A0A0A0;margin-top:2px}
.bkt-charts{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
.bkt-chart-card{background:#fff;border-radius:12px;padding:18px 16px;box-shadow:0 1px 4px rgba(0,0,0,.07)}
.bkt-card-title{font-size:11px;font-weight:700;color:#2E2E2E;text-transform:uppercase;letter-spacing:.06em;margin-bottom:3px}
.bkt-card-sub{font-size:9.5px;color:#A0A0A0;margin-bottom:12px}
/* Stage funnel */
.bkt-stage-row{display:flex;align-items:center;gap:8px;margin-bottom:10px}
.bkt-stage-labels{width:110px;flex-shrink:0}
.bkt-stage-name{display:block;font-size:11px;font-weight:600;color:#2E2E2E}
.bkt-stage-hindi{display:block;font-size:9px;color:#A0A0A0}
.bkt-stage-bar-wrap{flex:1;height:10px;background:#F0EBE3;border-radius:5px;overflow:hidden}
.bkt-stage-bar{height:100%;border-radius:5px;transition:width .5s}
.bkt-stage-meta{display:flex;flex-direction:column;align-items:flex-end;width:52px;flex-shrink:0}
.bkt-stage-n{font-size:11px;font-weight:700;white-space:nowrap}
.bkt-stage-pct{font-size:9px;color:#A0A0A0;white-space:nowrap}
.bkt-stage-days{font-size:9px;color:#E65100;white-space:nowrap}
/* Formal/Informal */
.bkt-fi-title{font-size:10px;font-weight:700;color:#2E2E2E;text-transform:uppercase;letter-spacing:.05em;margin:14px 0 6px}
.bkt-fi-row{display:flex;align-items:center;gap:8px;margin-bottom:7px}
.bkt-fi-label{font-size:10px;font-weight:600;color:#3E3E3E;width:40px;flex-shrink:0}
.bkt-fi-bar-wrap{flex:1;height:9px;border-radius:5px;overflow:hidden;display:flex}
.bkt-fi-bar-f{height:100%;background:#42A5F5}
.bkt-fi-bar-i{height:100%;background:#FFCA28}
.bkt-fi-pct{font-size:9px;color:#42A5F5;width:70px;flex-shrink:0;text-align:right}
/* Topics */
.bkt-topic-row{display:flex;align-items:center;gap:8px;margin-bottom:8px}
.bkt-topic-labels{width:90px;flex-shrink:0}
.bkt-topic-name{display:block;font-size:10.5px;font-weight:600;color:#2E2E2E;line-height:1.2}
.bkt-topic-bar-wrap{flex:1;height:8px;background:#F0EBE3;border-radius:4px;overflow:hidden}
.bkt-topic-bar{height:100%;border-radius:4px;transition:width .5s}
.bkt-topic-meta{display:flex;flex-direction:column;align-items:flex-end;width:48px;flex-shrink:0}
.bkt-topic-n{font-size:10px;font-weight:700;white-space:nowrap}
.bkt-topic-pct{font-size:9px;color:#A0A0A0;white-space:nowrap}
/* Duration */
.bkt-dur-row{display:flex;align-items:center;gap:8px;margin-bottom:8px}
.bkt-dur-label{font-size:10px;font-weight:600;color:#2E2E2E;width:90px;flex-shrink:0;line-height:1.2}
.bkt-dur-bar-wrap{flex:1;height:8px;background:#F0EBE3;border-radius:4px;overflow:hidden}
.bkt-dur-bar{height:100%;border-radius:4px;transition:width .5s}
.bkt-dur-val{font-size:10px;font-weight:700;width:52px;text-align:right;white-space:nowrap}
/* Legend */
.bkt-legend{display:flex;flex-wrap:wrap;gap:6px 12px;margin-top:14px;padding-top:10px;border-top:1px solid #F0EBE3}
.bkt-leg-item{display:flex;align-items:center;gap:5px;font-size:9.5px;color:#3E3E3E}
.bkt-leg-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
@media(max-width:1000px){.bkt-charts{grid-template-columns:1fr}.bkt-kpi-row{grid-template-columns:repeat(3,1fr)}}

/* ── BK Processing Unit (Section 17) ── */
.bkpu-kpi-row{display:grid;grid-template-columns:repeat(5,1fr);gap:12px;margin-bottom:20px}
.bkpu-kpi-card{background:#fff;border-radius:12px;padding:16px 14px;border-top:3px solid var(--kc,#01579B);box-shadow:0 1px 4px rgba(0,0,0,.06)}
.bkpu-kv{font-size:22px;font-weight:800;color:#1E1E1E;line-height:1}
.bkpu-kp{font-size:11px;font-weight:700;color:var(--kc,#01579B);margin-top:3px}
.bkpu-kl{font-size:10px;font-weight:600;color:#3E3E3E;margin-top:6px;text-transform:uppercase;letter-spacing:.04em}
.bkpu-kh{font-size:9.5px;color:#A0A0A0;margin-top:2px}
.bkpu-charts{display:grid;grid-template-columns:repeat(2,1fr);gap:16px}
.bkpu-chart-card{background:#fff;border-radius:12px;padding:18px 16px;box-shadow:0 1px 4px rgba(0,0,0,.07)}
.bkpu-card-title{font-size:11px;font-weight:700;color:#2E2E2E;text-transform:uppercase;letter-spacing:.06em;margin-bottom:3px}
.bkpu-card-sub{font-size:9.5px;color:#A0A0A0;margin-bottom:14px}
/* Stat grid */
.bkpu-stat-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:16px}
.bkpu-stat-item{background:#F8F6F2;border-radius:8px;padding:10px 8px;text-align:center}
.bkpu-stat-v{display:block;font-size:15px;font-weight:800;color:#1E1E1E;line-height:1.1}
.bkpu-stat-l{display:block;font-size:9px;color:#A0A0A0;margin-top:3px;text-transform:uppercase;letter-spacing:.04em}
/* Utilisation */
.bkpu-util-title{font-size:10px;font-weight:700;color:#2E2E2E;text-transform:uppercase;letter-spacing:.05em;margin-bottom:5px}
.bkpu-util-wrap{height:10px;background:#E3EDF7;border-radius:5px;overflow:hidden;margin-bottom:4px}
.bkpu-util-bar{height:100%;background:#0288D1;border-radius:5px;transition:width .5s}
.bkpu-util-label{font-size:10px;color:#0288D1;font-weight:600}
/* Varieties */
.bkpu-var-row{display:flex;align-items:center;gap:8px;margin-bottom:7px}
.bkpu-var-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0}
.bkpu-var-name{font-size:11px;font-weight:600;color:#2E2E2E;flex:1}
.bkpu-var-n{font-size:11px;font-weight:700}
/* Channels */
.bkpu-ch-row{margin-bottom:14px;padding-bottom:14px;border-bottom:1px solid #F5F2EE}
.bkpu-ch-row:last-of-type{border-bottom:none}
.bkpu-ch-head{display:flex;align-items:center;gap:8px;margin-bottom:5px}
.bkpu-ch-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0}
.bkpu-ch-info{flex:1}
.bkpu-ch-name{display:block;font-size:11px;font-weight:700;color:#2E2E2E}
.bkpu-ch-hindi{display:block;font-size:9px;color:#A0A0A0}
.bkpu-ch-n{font-size:12px;font-weight:800}
.bkpu-ch-bar-wrap{height:8px;background:#F0EBE3;border-radius:4px;overflow:hidden;margin-bottom:4px}
.bkpu-ch-bar{height:100%;border-radius:4px;transition:width .5s}
.bkpu-ch-meta{display:flex;gap:12px}
.bkpu-ch-qty{font-size:10px;color:#666}
.bkpu-ch-price{font-size:10px;font-weight:700;color:#2E2E2E}
.bkpu-ch-nil{font-size:10px;color:#C5BAB0;font-style:italic;padding:2px 0 0 18px}
.bkpu-note{margin-top:16px;padding:10px 12px;background:#FFF8E1;border-radius:8px;font-size:10.5px;color:#795548;line-height:1.5;border-left:3px solid #FFC107}
@media(max-width:1000px){.bkpu-charts{grid-template-columns:1fr}.bkpu-kpi-row{grid-template-columns:repeat(3,1fr)}}

/* ── BK Export (Sections 18 & 19) ── */
.bkex-kpi-row{display:grid;grid-template-columns:repeat(5,1fr);gap:12px;margin-bottom:20px}
.bkex-kpi-card{background:#fff;border-radius:12px;padding:16px 14px;border-top:3px solid var(--kc,#1A237E);box-shadow:0 1px 4px rgba(0,0,0,.06)}
.bkex-kv{font-size:22px;font-weight:800;color:#1E1E1E;line-height:1}
.bkex-kp{font-size:11px;font-weight:700;color:var(--kc,#1A237E);margin-top:3px}
.bkex-kl{font-size:10px;font-weight:600;color:#3E3E3E;margin-top:6px;text-transform:uppercase;letter-spacing:.04em}
.bkex-kh{font-size:9.5px;color:#A0A0A0;margin-top:2px}
.bkex-charts{display:grid;grid-template-columns:repeat(2,1fr);gap:16px}
.bkex-chart-card{background:#fff;border-radius:12px;padding:18px 16px;box-shadow:0 1px 4px rgba(0,0,0,.07)}
.bkex-card-title{font-size:11px;font-weight:700;color:#2E2E2E;text-transform:uppercase;letter-spacing:.06em;margin-bottom:3px}
.bkex-card-sub{font-size:9.5px;color:#A0A0A0;margin-bottom:12px}
.bkex-sub-title{font-size:10px;font-weight:700;color:#2E2E2E;text-transform:uppercase;letter-spacing:.05em;margin:12px 0 7px}
/* Self vs Agency mode */
.bkex-mode-row{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px}
.bkex-mode-card{background:#F8F6F2;border-radius:8px;padding:10px 12px;border-left:3px solid var(--mc,#333)}
.bkex-mode-v{display:block;font-size:18px;font-weight:800;color:#1E1E1E}
.bkex-mode-l{display:block;font-size:9px;color:#A0A0A0;margin-top:2px;text-transform:uppercase;letter-spacing:.04em}
.bkex-mode-p{display:block;font-size:11px;font-weight:700;color:var(--mc,#333);margin-top:3px}
/* Destination rows */
.bkex-dest-row{display:flex;align-items:center;gap:8px;margin-bottom:7px}
.bkex-dest-name{font-size:10.5px;font-weight:600;color:#2E2E2E;width:90px;flex-shrink:0}
.bkex-dest-bar-wrap{flex:1;height:8px;background:#EEF0F8;border-radius:4px;overflow:hidden}
.bkex-dest-bar{height:100%;border-radius:4px;transition:width .5s}
.bkex-dest-n{font-size:10px;font-weight:700;color:#555;width:24px;text-align:right;flex-shrink:0}
/* Abroad box */
.bkex-abroad-box{display:flex;align-items:center;gap:12px;background:#FFF8E1;border-radius:8px;padding:12px;margin-top:14px;border-left:3px solid #FFB300}
.bkex-abroad-icon{font-size:22px;flex-shrink:0}
.bkex-abroad-text{flex:1;display:flex;flex-direction:column;gap:2px}
.bkex-abroad-text strong{font-size:11px;font-weight:700;color:#5D4037}
.bkex-abroad-text span{font-size:9.5px;color:#A0A0A0}
.bkex-abroad-zero{font-size:28px;font-weight:900;color:#FFCA28;line-height:1}
/* Volume comparison */
.bkex-vol-row{display:flex;align-items:center;gap:8px;margin-bottom:7px}
.bkex-vol-label{font-size:10px;font-weight:600;color:#2E2E2E;width:80px;flex-shrink:0}
.bkex-vol-bar-wrap{flex:1;height:8px;background:#EEF0F8;border-radius:4px;overflow:hidden}
.bkex-vol-bar{height:100%;border-radius:4px;transition:width .5s}
.bkex-vol-val{font-size:10px;font-weight:700;color:#555;width:72px;text-align:right;flex-shrink:0;white-space:nowrap}
@media(max-width:1000px){.bkex-charts{grid-template-columns:1fr}.bkex-kpi-row{grid-template-columns:repeat(3,1fr)}}

/* ── BK Beeswax Export (Section 20) ── */
.bkbx-kpi-row{display:grid;grid-template-columns:repeat(5,1fr);gap:12px;margin-bottom:20px}
.bkbx-kpi-card{background:#fff;border-radius:12px;padding:16px 14px;border-top:3px solid var(--kc,#4A148C);box-shadow:0 1px 4px rgba(0,0,0,.06)}
