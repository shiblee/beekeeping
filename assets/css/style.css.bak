.bkbx-card-title{font-size:11px;font-weight:700;color:#2E2E2E;text-transform:uppercase;letter-spacing:.06em;margin-bottom:3px}
.bkbx-card-sub{font-size:9.5px;color:#A0A0A0;margin-bottom:12px}
.bkbx-sub-title{font-size:10px;font-weight:700;color:#2E2E2E;text-transform:uppercase;letter-spacing:.05em;margin:12px 0 7px}
.bkbx-mode-row{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px}
.bkbx-mode-card{background:#F8F6F2;border-radius:8px;padding:10px 12px;border-left:3px solid var(--mc,#333)}
.bkbx-mode-v{display:block;font-size:18px;font-weight:800;color:#1E1E1E}
.bkbx-mode-l{display:block;font-size:9px;color:#A0A0A0;margin-top:2px;text-transform:uppercase;letter-spacing:.04em}
.bkbx-mode-p{display:block;font-size:11px;font-weight:700;color:var(--mc,#333);margin-top:3px}
.bkbx-dest-row{display:flex;align-items:center;gap:8px;margin-bottom:7px}
.bkbx-dest-name{font-size:10.5px;font-weight:600;color:#2E2E2E;width:90px;flex-shrink:0}
.bkbx-dest-bar-wrap{flex:1;height:8px;background:#F3EEF8;border-radius:4px;overflow:hidden}
.bkbx-dest-bar{height:100%;border-radius:4px;transition:width .5s}
.bkbx-dest-n{font-size:10px;font-weight:700;color:#555;width:24px;text-align:right;flex-shrink:0}
.bkbx-abroad-box{display:flex;align-items:center;gap:12px;background:#FFF8E1;border-radius:8px;padding:12px;margin-top:14px;border-left:3px solid #FFB300}
.bkbx-abroad-icon{font-size:22px;flex-shrink:0}
.bkbx-abroad-text{flex:1;display:flex;flex-direction:column;gap:2px}
.bkbx-abroad-text strong{font-size:11px;font-weight:700;color:#5D4037}
.bkbx-abroad-text span{font-size:9.5px;color:#A0A0A0}
.bkbx-abroad-zero{font-size:28px;font-weight:900;color:#FFCA28;line-height:1}
.bkbx-vol-row{display:flex;align-items:center;gap:8px;margin-bottom:7px}
.bkbx-vol-label{font-size:10px;font-weight:600;color:#2E2E2E;width:80px;flex-shrink:0}
.bkbx-vol-bar-wrap{flex:1;height:8px;background:#F3EEF8;border-radius:4px;overflow:hidden}
.bkbx-vol-bar{height:100%;border-radius:4px;transition:width .5s}
.bkbx-vol-val{font-size:10px;font-weight:700;width:72px;text-align:right;flex-shrink:0;white-space:nowrap}
@media(max-width:1000px){.bkbx-charts{grid-template-columns:1fr}.bkbx-kpi-row{grid-template-columns:repeat(3,1fr)}}

/* ── BK Market & Schemes (Sections 21 & 22) ── */
.bkmc-kpi-row{display:grid;grid-template-columns:repeat(5,1fr);gap:12px;margin-bottom:20px}
.bkmc-kpi-card{background:#fff;border-radius:12px;padding:16px 14px;border-top:3px solid var(--kc,#B71C1C);box-shadow:0 1px 4px rgba(0,0,0,.06)}
.bkmc-kv{font-size:22px;font-weight:800;color:#1E1E1E;line-height:1}
.bkmc-kp{font-size:11px;font-weight:700;color:var(--kc,#B71C1C);margin-top:3px}
.bkmc-kl{font-size:10px;font-weight:600;color:#3E3E3E;margin-top:6px;text-transform:uppercase;letter-spacing:.04em}
.bkmc-kh{font-size:9.5px;color:#A0A0A0;margin-top:2px}
.bkmc-charts{display:grid;grid-template-columns:1fr 2fr;gap:16px}
.bkmc-chart-card{background:#fff;border-radius:12px;padding:18px 16px;box-shadow:0 1px 4px rgba(0,0,0,.07)}
.bkmc-span2{grid-column:span 1}
.bkmc-card-title{font-size:11px;font-weight:700;color:#2E2E2E;text-transform:uppercase;letter-spacing:.06em;margin-bottom:3px}
.bkmc-card-sub{font-size:9.5px;color:#A0A0A0;margin-bottom:12px}
/* Market competition bars */
.bkmc-mc-row{display:flex;align-items:center;gap:8px;margin-bottom:9px}
.bkmc-mc-labels{width:110px;flex-shrink:0}
.bkmc-mc-name{display:block;font-size:11px;font-weight:700}
.bkmc-mc-bar-wrap{flex:1;height:9px;background:#F5F0E8;border-radius:5px;overflow:hidden}
.bkmc-mc-bar{height:100%;border-radius:5px;transition:width .5s}
.bkmc-mc-meta{display:flex;flex-direction:column;align-items:flex-end;width:46px;flex-shrink:0}
.bkmc-mc-n{font-size:11px;font-weight:700}
.bkmc-mc-pct{font-size:9px;color:#A0A0A0}
/* Scheme grid */
.bkmc-scheme-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px 20px}
.bkmc-scheme-row{padding-bottom:12px;border-bottom:1px solid #F5F0E8}
.bkmc-sch-head{display:flex;align-items:flex-start;gap:8px;margin-bottom:6px}
.bkmc-sch-code{font-size:9px;font-weight:800;padding:2px 6px;border-radius:4px;border:1px solid;white-space:nowrap;flex-shrink:0;margin-top:1px;letter-spacing:.04em}
.bkmc-sch-info{flex:1;min-width:0}
.bkmc-sch-full{display:block;font-size:10.5px;font-weight:600;color:#2E2E2E;line-height:1.3}
.bkmc-sch-hindi{display:block;font-size:9px;color:#A0A0A0;margin-top:1px}
.bkmc-sch-nums{display:flex;flex-direction:column;align-items:flex-end;flex-shrink:0}
.bkmc-sch-r{font-size:15px;font-weight:800;line-height:1}
.bkmc-sch-rl{font-size:8.5px;color:#A0A0A0;text-transform:uppercase;letter-spacing:.04em}
.bkmc-sch-bar-wrap{height:8px;background:#F0EBE3;border-radius:4px;overflow:hidden;display:flex;margin-bottom:4px}
.bkmc-sch-bar-r{height:100%;border-radius:4px 0 0 4px;transition:width .5s}
.bkmc-sch-bar-b{height:100%;transition:width .5s}
.bkmc-sch-foot{display:flex;align-items:center;gap:8px;flex-wrap:wrap}
.bkmc-sch-rpct{font-size:9px;color:#A0A0A0}
.bkmc-sch-bpill{font-size:9px;font-weight:600;padding:1px 6px;border-radius:10px}
.bkmc-sch-nil{font-size:9px;color:#C5BAB0;font-style:italic}
@media(max-width:1100px){.bkmc-charts{grid-template-columns:1fr}.bkmc-scheme-grid{grid-template-columns:1fr}.bkmc-kpi-row{grid-template-columns:repeat(3,1fr)}}

/* ── BK Dept Help (Section 23) ── */
.bkh-kpi-row{display:grid;grid-template-columns:repeat(5,1fr);gap:12px;margin-bottom:20px}
.bkh-kpi-card{background:#fff;border-radius:12px;padding:16px 14px;border-top:3px solid var(--kc,#1B5E20);box-shadow:0 1px 4px rgba(0,0,0,.06)}
.bkh-kv{font-size:22px;font-weight:800;color:#1E1E1E;line-height:1}
.bkh-kp{font-size:11px;font-weight:700;color:var(--kc,#1B5E20);margin-top:3px}
.bkh-kl{font-size:10px;font-weight:600;color:#3E3E3E;margin-top:6px;text-transform:uppercase;letter-spacing:.04em}
.bkh-kh{font-size:9.5px;color:#A0A0A0;margin-top:2px}
.bkh-charts{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
.bkh-chart-card{background:#fff;border-radius:12px;padding:18px 16px;box-shadow:0 1px 4px rgba(0,0,0,.07)}
.bkh-card-title{font-size:11px;font-weight:700;color:#2E2E2E;text-transform:uppercase;letter-spacing:.06em;margin-bottom:3px}
.bkh-card-sub{font-size:9.5px;color:#A0A0A0;margin-bottom:12px}
/* Help types */
.bkh-type-row{display:flex;align-items:center;gap:8px;margin-bottom:10px}
.bkh-type-labels{width:110px;flex-shrink:0}
.bkh-type-name{display:block;font-size:10.5px;font-weight:600;color:#2E2E2E;line-height:1.2}
.bkh-type-hindi{display:block;font-size:9px;color:#A0A0A0;margin-top:1px}
.bkh-type-bar-wrap{flex:1;height:9px;background:#F0EBE3;border-radius:5px;overflow:hidden}
.bkh-type-bar{height:100%;border-radius:5px;transition:width .5s}
.bkh-type-meta{display:flex;flex-direction:column;align-items:flex-end;width:36px;flex-shrink:0}
.bkh-type-n{font-size:11px;font-weight:700}
.bkh-type-pct{font-size:9px;color:#A0A0A0}
/* DBT table */
.bkh-dbt-table{display:flex;flex-direction:column;gap:7px;margin-top:8px}
.bkh-dbt-row{display:flex;align-items:center;gap:7px;background:#F8F6F2;border-radius:7px;padding:6px 8px}
.bkh-dbt-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.bkh-dbt-label{flex:1;font-size:10px;font-weight:600;color:#2E2E2E}
.bkh-dbt-avg{font-size:10px;font-weight:700;white-space:nowrap}
.bkh-dbt-total{font-size:9.5px;color:#888;white-space:nowrap}
/* Scheme bars */
.bkh-sch-row{display:flex;align-items:center;gap:8px;margin-bottom:9px}
.bkh-sch-labels{width:140px;flex-shrink:0}
.bkh-sch-name{display:block;font-size:10.5px;font-weight:600;color:#2E2E2E;line-height:1.2}
.bkh-sch-bar-wrap{flex:1;height:9px;background:#F0EBE3;border-radius:5px;overflow:hidden}
.bkh-sch-bar{height:100%;border-radius:5px;transition:width .5s}
.bkh-sch-meta{display:flex;flex-direction:column;align-items:flex-end;width:36px;flex-shrink:0}
.bkh-sch-n{font-size:11px;font-weight:700}
.bkh-sch-pct{font-size:9px;color:#A0A0A0}
/* Year bars */
.bkh-yr-row{display:flex;align-items:center;gap:8px;margin-bottom:8px}
.bkh-yr-label{font-size:11px;font-weight:700;color:#2E2E2E;width:38px;flex-shrink:0;text-align:right}
.bkh-yr-bar-wrap{flex:1;height:9px;background:#E8F5E9;border-radius:5px;overflow:hidden}
.bkh-yr-bar{height:100%;border-radius:5px;background:#2E7D32;transition:width .5s}
.bkh-yr-n{font-size:11px;font-weight:700;color:#2E7D32;width:24px;text-align:right;flex-shrink:0}
.bkh-note{margin-top:14px;padding:10px 12px;background:#E8F5E9;border-radius:8px;font-size:10.5px;color:#2E7D32;line-height:1.5;border-left:3px solid #4CAF50}
@media(max-width:1000px){.bkh-charts{grid-template-columns:1fr}.bkh-kpi-row{grid-template-columns:repeat(3,1fr)}}

/* ── BK Membership (Section 24) ── */
.bkmem-kpi-row{display:grid;grid-template-columns:repeat(5,1fr);gap:12px;margin-bottom:20px}
.bkmem-kpi-card{background:#fff;border-radius:12px;padding:16px 14px;border-top:3px solid var(--kc,#880E4F);box-shadow:0 1px 4px rgba(0,0,0,.06)}
.bkmem-kv{font-size:22px;font-weight:800;color:#1E1E1E;line-height:1}
.bkmem-kp{font-size:11px;font-weight:700;color:var(--kc,#880E4F);margin-top:3px}
.bkmem-kl{font-size:10px;font-weight:600;color:#3E3E3E;margin-top:6px;text-transform:uppercase;letter-spacing:.04em}
.bkmem-kh{font-size:9.5px;color:#A0A0A0;margin-top:2px}
.bkmem-charts{display:grid;grid-template-columns:3fr 2fr;gap:16px}
.bkmem-chart-card{background:#fff;border-radius:12px;padding:18px 16px;box-shadow:0 1px 4px rgba(0,0,0,.07)}
.bkmem-card-title{font-size:11px;font-weight:700;color:#2E2E2E;text-transform:uppercase;letter-spacing:.06em;margin-bottom:3px}
.bkmem-card-sub{font-size:9.5px;color:#A0A0A0;margin-bottom:12px}
/* Institution bars */
.bkmem-inst-row{display:flex;align-items:center;gap:8px;margin-bottom:9px}
.bkmem-inst-labels{width:180px;flex-shrink:0}
.bkmem-inst-name{display:block;font-size:10.5px;font-weight:600;color:#2E2E2E;line-height:1.2}
.bkmem-inst-bar-wrap{flex:1;height:9px;background:#FCE4EC;border-radius:5px;overflow:hidden}
.bkmem-inst-bar{height:100%;border-radius:5px;transition:width .5s}
.bkmem-inst-meta{display:flex;flex-direction:column;align-items:flex-end;width:36px;flex-shrink:0}
.bkmem-inst-n{font-size:11px;font-weight:700}
.bkmem-inst-pct{font-size:9px;color:#A0A0A0}
/* Benefit cards */
.bkmem-ben-strip{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px}
.bkmem-ben-card{background:#F8F6F2;border-radius:8px;padding:12px;border-left:3px solid var(--bc)}
.bkmem-ben-v{font-size:20px;font-weight:800;color:#1E1E1E;line-height:1}
.bkmem-ben-p{font-size:12px;font-weight:700;color:var(--bc);margin-top:2px}
.bkmem-ben-l{font-size:10px;font-weight:600;color:#3E3E3E;margin-top:5px;text-transform:uppercase;letter-spacing:.04em}
.bkmem-ben-h{font-size:9px;color:#A0A0A0;margin-top:1px}
.bkmem-ben-bar-wrap{height:8px;border-radius:4px;overflow:hidden;display:flex;margin-bottom:14px}
.bkmem-ben-bar-yes{height:100%;background:#2E7D32;transition:width .5s}
.bkmem-ben-bar-no{height:100%;background:#E53935;transition:width .5s}
/* Membership depth */
.bkmem-depth-row{display:flex;align-items:center;gap:8px;margin-bottom:8px}
.bkmem-depth-label{font-size:10.5px;font-weight:600;color:#2E2E2E;width:90px;flex-shrink:0}
.bkmem-depth-bar-wrap{flex:1;height:8px;background:#FCE4EC;border-radius:4px;overflow:hidden}
.bkmem-depth-bar{height:100%;border-radius:4px;transition:width .5s}
.bkmem-depth-n{font-size:11px;font-weight:700;width:32px;text-align:right;flex-shrink:0}
/* Secondary tags */
.bkmem-inst2-list{display:flex;flex-wrap:wrap;gap:5px;margin-top:6px}
.bkmem-inst2-tag{font-size:9px;font-weight:600;padding:3px 8px;background:#FCE4EC;color:#880E4F;border-radius:10px;border:1px solid #F48FB1}
@media(max-width:1000px){.bkmem-charts{grid-template-columns:1fr}.bkmem-kpi-row{grid-template-columns:repeat(3,1fr)}}

/* ── BK Factors & Obstacles (Sections 25-29) ── */
.bkob-kpi-row{display:grid;grid-template-columns:repeat(5,1fr);gap:12px;margin-bottom:20px}
.bkob-kpi-card{background:#fff;border-radius:12px;padding:16px 14px;border-top:3px solid var(--kc,#B71C1C);box-shadow:0 1px 4px rgba(0,0,0,.06)}
.bkob-kv{font-size:22px;font-weight:800;color:#1E1E1E;line-height:1}
.bkob-kp{font-size:11px;font-weight:700;color:var(--kc,#B71C1C);margin-top:3px}
.bkob-kl{font-size:10px;font-weight:600;color:#3E3E3E;margin-top:6px;text-transform:uppercase;letter-spacing:.04em}
.bkob-kh{font-size:9.5px;color:#A0A0A0;margin-top:2px}
.bkob-charts{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
.bkob-chart-card{background:#fff;border-radius:12px;padding:18px 16px;box-shadow:0 1px 4px rgba(0,0,0,.07)}
.bkob-card-title{font-size:11px;font-weight:700;color:#2E2E2E;text-transform:uppercase;letter-spacing:.06em;margin-bottom:3px}
.bkob-card-sub{font-size:9.5px;color:#A0A0A0;margin-bottom:10px}
/* Shared bar rows */
.bkob-bar-row{display:flex;align-items:center;gap:6px;margin-bottom:7px}
.bkob-bar-label{font-size:10px;font-weight:600;color:#2E2E2E;width:100px;flex-shrink:0;line-height:1.2;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.bkob-bar-wrap{flex:1;height:8px;background:#F5F0E8;border-radius:4px;overflow:hidden}
.bkob-bar{height:100%;border-radius:4px;transition:width .5s}
.bkob-bar-n{font-size:10px;font-weight:700;width:38px;text-align:right;flex-shrink:0;white-space:nowrap}
.bkob-bar-pct{font-size:9px;color:#A0A0A0;width:32px;flex-shrink:0}
/* Pollination rental */
.bkob-rental-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:10px}
.bkob-rental-card{background:#F8F6F2;border-radius:8px;padding:10px 8px;text-align:center;border-top:2px solid var(--rc)}
.bkob-rent-v{display:block;font-size:16px;font-weight:800;color:#1E1E1E}
.bkob-rent-l{display:block;font-size:8.5px;color:#A0A0A0;margin-top:2px;text-transform:uppercase;letter-spacing:.04em}
.bkob-rent-p{display:block;font-size:10px;font-weight:700;color:var(--rc);margin-top:3px}
.bkob-rent-rec-hdr{font-size:9.5px;font-weight:700;color:var(--rrc,#F2A900);border-left:3px solid var(--rrc,#F2A900);padding-left:6px;margin-bottom:6px}
@media(max-width:1000px){.bkob-charts{grid-template-columns:1fr}.bkob-kpi-row{grid-template-columns:repeat(3,1fr)}}

/* ── BK CONTRACT & VARIETY (Sec 30+31) ── */
.bkct-kpi-row{display:grid;grid-template-columns:repeat(5,1fr);gap:10px;margin-bottom:18px}
.bkct-kpi-card{background:#fff;border-radius:12px;padding:14px 12px;border-top:3px solid var(--kc);box-shadow:0 1px 4px rgba(0,0,0,.06)}
.bkct-kv{font-size:22px;font-weight:700;color:var(--kc)}
.bkct-kp{font-size:10px;color:#A0A0A0;margin-top:2px}
.bkct-kl{font-size:10px;font-weight:600;color:#2E2E2E;margin-top:6px}
.bkct-kh{font-size:9px;color:#A0A0A0;margin-top:1px}
.bkct-charts{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.bkct-chart-card{background:#fff;border-radius:12px;padding:18px 16px;box-shadow:0 1px 4px rgba(0,0,0,.07)}
.bkct-card-title{font-size:11px;font-weight:700;color:#2E2E2E;letter-spacing:.4px;text-transform:uppercase}
.bkct-card-sub{font-size:9.5px;color:#A0A0A0;margin-top:2px;margin-bottom:10px}
.bkct-fact-row{display:flex;align-items:flex-start;gap:10px;margin-bottom:10px}
.bkct-fact-icon{font-size:18px;line-height:1}
.bkct-fact-body{display:flex;flex-direction:column}
.bkct-fact-label{font-size:10px;font-weight:700;color:#A0A0A0;text-transform:uppercase;letter-spacing:.3px}
.bkct-fact-val{font-size:12px;color:#2E2E2E;margin-top:2px}
.bkct-bar-row{display:grid;grid-template-columns:110px 1fr 40px 36px;align-items:center;gap:6px;margin-bottom:6px}
.bkct-bar-label{font-size:9.5px;color:#4A4A4A;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.bkct-bar-wrap{background:#F5F0E8;border-radius:3px;height:10px;overflow:hidden}
.bkct-bar{height:100%;border-radius:3px;transition:width .4s}
.bkct-bar-n{font-size:10px;font-weight:700;text-align:right}
.bkct-bar-pct{font-size:9px;color:#A0A0A0;text-align:right}
.bkct-note{font-size:10px;color:#6B6B6B;background:#F8F6F2;border-radius:6px;padding:9px 11px;border-left:3px solid #BDBDBD;line-height:1.5}
.bkct-split-row{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px}
.bkct-split-card{background:#F8F6F2;border-radius:8px;padding:12px;border-top:3px solid var(--sc);text-align:center}
.bkct-split-v{display:block;font-size:20px;font-weight:700;color:var(--sc)}
.bkct-split-p{display:block;font-size:11px;color:#A0A0A0;margin-top:1px}
.bkct-split-l{display:block;font-size:10px;font-weight:600;color:#2E2E2E;margin-top:5px}
.bkct-split-h{display:block;font-size:9px;color:#A0A0A0;margin-top:1px}
.bkct-split-bar-wrap{display:flex;border-radius:4px;overflow:hidden;height:8px;margin-bottom:14px}
.bkct-split-bar-y{background:#2E7D32;height:100%}
.bkct-split-bar-n{background:#BDBDBD;height:100%}
@media(max-width:1000px){.bkct-charts{grid-template-columns:1fr}.bkct-kpi-row{grid-template-columns:repeat(3,1fr)}}

.stat3{display:grid;grid-template-columns:repeat(3,1fr);gap:0}
.stat3-cell{text-align:center;padding:14px 10px}
.stat3-val{font-size:24px;font-weight:700}
.stat3-lbl{font-size:10px;color:#6B6B6B;margin-top:2px}

/* ── Map panel ── */
.map-hdr{display:none}
.map-legend{display:flex;align-items:center;gap:10px;flex-wrap:wrap;font-size:11px;color:#6B6B6B;background:#FFFDF7;border:1px solid #F0E6D6;border-radius:10px;padding:8px 14px}
.ml-item{display:flex;align-items:center;gap:5px}
.ml-dot{width:12px;height:12px;border-radius:50%;display:inline-block;flex-shrink:0}
.ml-sep{width:1px;height:16px;background:#F0E6D6}
.ml-note{font-style:italic;color:#A8A8A8}

/* Map two-column layout */
.map-layout{display:grid;grid-template-columns:1fr 420px;gap:18px;align-items:start}
.map-col-map{}
.up-map-wrap{width:100%;height:620px;border-radius:14px;overflow:hidden;box-shadow:0 3px 16px rgba(0,0,0,.09);border:1px solid #F0E6D6}

/* Indicators sidebar */
.map-col-sidebar{display:flex;flex-direction:column;gap:14px;height:620px}
.map-col-sidebar .ind-block{flex:1;display:flex;flex-direction:column}
.map-col-sidebar .ind-rank-list{flex:1;justify-content:space-evenly;display:flex;flex-direction:column}
.ind-block{background:#fff;border-radius:14px;padding:14px 16px;box-shadow:0 3px 12px rgba(0,0,0,.06)}
.ind-block-title{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:#A8A8A8;margin-bottom:12px;padding-bottom:8px;border-bottom:1px solid #F7F0E8}
.ind-hover{border:2px solid #F6C453}
.map-tooltip{background:#fff;border:1px solid #F0E6D6;border-radius:10px;padding:8px 12px;font-size:12px;color:#2E2E2E;box-shadow:0 4px 12px rgba(0,0,0,.1);line-height:1.6}

/* KPI mini grid */
.ind-kpi-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px}
.ind-kpi{background:#FFFDF7;border-radius:10px;padding:10px 8px;text-align:center;border-top:3px solid var(--ik,#F2A900)}
.ind-kpi-val{font-size:18px;font-weight:700;color:#1E1E1E;line-height:1}
.ind-kpi-lbl{font-size:9.5px;color:#8A8A8A;margin-top:3px;text-transform:uppercase;letter-spacing:.06em}

/* Rank list — legacy kept for safety */
.ind-rank-list{display:flex;flex-direction:column;gap:8px}

/* Enriched rank rows */
.ind-rich-list{display:flex;flex-direction:column;gap:10px;flex:1;justify-content:space-evenly}
.ind-rich-row{display:flex;flex-direction:column;gap:5px}
.ind-rich-top{display:flex;align-items:center;gap:6px}
.ind-medal{font-size:14px;flex-shrink:0;width:22px;text-align:center}
.ind-rich-name{font-size:13px;font-weight:700;color:#1E1E1E;flex:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.ind-rich-count{font-size:15px;font-weight:800;color:#F2A900;flex-shrink:0}
.ind-rich-share{font-size:10px;color:#A8A8A8;flex-shrink:0}
.ind-rich-bar-wrap{height:8px;background:#F7F0E8;border-radius:4px;overflow:hidden;margin:0 2px}
.ind-rich-bar{height:100%;border-radius:4px;background:linear-gradient(90deg,#F6C453,#F2A900);transition:width .6s}
.ind-rich-meta{display:flex;gap:5px;flex-wrap:wrap}
.ind-meta-pill{font-size:10px;font-weight:600;padding:2px 8px;border-radius:20px;white-space:nowrap}

@media(max-width:1000px){.map-layout{grid-template-columns:1fr}.map-col-sidebar{flex-direction:row;flex-wrap:wrap}.ind-block{flex:1;min-width:200px}}
/* Leaflet bubble label */
.dist-label{pointer-events:none;text-align:center;white-space:nowrap}
.dl-name{display:block;font-size:9px;font-weight:600;color:#2E2E2E;text-shadow:0 0 3px #fff,0 0 3px #fff,0 0 3px #fff,0 0 3px #fff;line-height:1.2}
.dl-num{display:block;font-size:11px;font-weight:800;color:#B22222;text-shadow:0 0 4px #fff,0 0 4px #fff;line-height:1.1}
/* Info card */
.map-info-card{position:relative;margin-top:14px;background:#fff;border-radius:14px;padding:16px 20px;box-shadow:0 3px 16px rgba(0,0,0,.09);border:1px solid #F0E6D6;max-width:420px}
.mic-name{font-size:16px;font-weight:700;color:#2E2E2E;margin-bottom:10px}
.mic-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:12px}
.mic-kv span{display:block;font-size:9px;text-transform:uppercase;letter-spacing:.06em;color:#A8A8A8}
.mic-kv strong{display:block;font-size:15px;font-weight:700;color:#2E2E2E}
.mic-bars{display:flex;flex-direction:column;gap:7px}
.mic-bar-row{display:flex;align-items:center;gap:8px;font-size:11px;color:#6B6B6B}
.mic-bar-row span:first-child{width:44px;flex-shrink:0}
.mic-bar-bg{flex:1;height:10px;background:#F0E6D6;border-radius:5px;overflow:hidden}
.mic-bar-fill{height:100%;border-radius:5px;transition:width .4s}
.mic-bar-fill.green{background:linear-gradient(90deg,#81C784,#43A047)}
.mic-bar-fill.purple{background:linear-gradient(90deg,#CE93D8,#7B1FA2)}
.mic-bar-row span:last-child{width:34px;text-align:right;font-weight:600}
